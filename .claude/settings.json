{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/preflight.sh",
            "timeout": 10,
            "statusMessage": "Running harness preflight..."
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/evidence-completeness.sh",
            "timeout": 10,
            "statusMessage": "Checking harness evidence expectations..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/evidence-completeness.sh --stop",
            "timeout": 10,
            "statusMessage": "Checking harness closeout evidence..."
          }
        ]
      }
    ]
  }
}

WAKE_STREAM_CONFIRM_THRESHOLD=1
WAKE_STREAM_MAX_BUFFER_DURATION_SEC=15
WAKE_STREAM_IDLE_TIMEOUT_SEC=5
# Optional fixed-mode override. Leave empty for dashboard-linked auto discovery.
VEXA_NATIVE_MEETING_ID=
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
GROQ_MAX_COMPLETION_TOKENS=768

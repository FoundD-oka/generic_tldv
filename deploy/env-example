# --- Vexa Environment ---
# Copy to repo root as .env:  cp deploy/env-example .env
# Then edit the REQUIRED fields below.

# ============================================================================
# REQUIRED — you MUST set these
# ============================================================================

# Transcription service
# Get a key at vexa.ai OR self-host services/transcription-service/ with GPU
TRANSCRIPTION_SERVICE_URL=https://transcription.vexa.ai/v1/audio/transcriptions
TRANSCRIPTION_SERVICE_TOKEN=your-token

# ============================================================================
# Ports — change these to avoid conflicts with other stacks
# ============================================================================
API_GATEWAY_HOST_PORT=8056
ADMIN_API_PORT=8057
RUNTIME_API_PORT=8090
AGENT_API_PORT=8100
CALENDAR_SERVICE_PORT=8050
DASHBOARD_HOST_PORT=3001
POSTGRES_HOST_PORT=5458
MCP_HOST_PORT=18888
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
WAKE_STT_HOST_PORT=8058

# ============================================================================
# Defaults — work as-is for local dev
# ============================================================================

# Admin
ADMIN_TOKEN=changeme

# Image tag — pre-built from DockerHub by default.
# `make build` writes a local tag to .last-tag which overrides this.
IMAGE_TAG=latest
BROWSER_IMAGE=vexaai/vexa-bot:latest


# Database (embedded postgres by default)
DB_NAME=vexa
DB_USER=postgres
DB_PASSWORD=postgres
# For external DB, uncomment:
# REMOTE_DB=true
# DB_HOST=your-postgres-host
# DB_PORT=5432

# Storage (embedded minio by default)
STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=vexa-access-key
MINIO_SECRET_KEY=vexa-secret-key
MINIO_BUCKET=vexa
MINIO_SECURE=false

# Google Cloud Storage backend (issue #1) — recordings source of truth with a
# 14d Standard -> Nearline / 60d delete lifecycle. Uses ADC / Workload Identity
# (no HMAC key in the app); signed URLs via IAM signBlob. See deploy/gcs/README.md.
# STORAGE_BACKEND=gcs
# GCS_BUCKET=vexa-recordings
# GCS_PROJECT=                       # optional; inferred from ADC if omitted
# GCS_SIGNING_SERVICE_ACCOUNT=       # optional; runtime SA email for signBlob, derived from ADC if omitted
# GOOGLE_CLOUD_PROJECT=              # optional; defaults to GCS_PROJECT in compose
# GOOGLE_APPLICATION_CREDENTIALS_HOST=~/.config/gcloud/application_default_credentials.json
# GOOGLE_APPLICATION_CREDENTIALS=/var/secrets/google/application_default_credentials.json

# Local GPU transcription (uncomment to self-host)
# LOCAL_TRANSCRIPTION=true

# Optional Piper TTS service. Kabosu wake replies use Aivis Cloud audio_base64;
# enable compose profile `tts` only when you need text /speak through Piper.
# Voice models auto-download from HuggingFace on first use.

# Kabosu Wake Orchestrator (optional; run compose with profile `wake`)
# Keeps the visible meeting assistant name aligned with the Kabosu dashboard.
# Required for wake: VEXA_API_KEY, GROQ_API_KEY, AIVIS_API_KEY,
# AIVIS_MODEL_UUID. VEXA_API_KEY must belong to the same dashboard user who
# creates the bots, because /bots/status is user-scoped.
# By default it discovers dashboard-created running bots through Vexa.
VEXA_PLATFORM=google_meet
WAKE_AUTO_DISCOVER_BOTS=true
WAKE_DISCOVERY_INTERVAL_SECONDS=5
# Optional low-latency wake transcript lane. Leave WAKE_STT_URL empty to keep
# Wake Orchestrator on the existing Vexa transcript WebSocket. To enable it,
# set WAKE_STT_URL=http://wake-stt:8058 and start compose with both
# `--profile wake --profile wake-stt`.
WAKE_STT_URL=
WAKE_STT_API_TOKEN=
WAKE_STT_LANGUAGE=ja
WAKE_STT_MIN_WINDOW_MS=600
WAKE_STT_MAX_WINDOW_MS=2200
WAKE_STT_SUBMIT_INTERVAL_MS=650
WAKE_STT_IDLE_RESET_MS=1400
WAKE_STT_FLUSH_INTERVAL_MS=500
WAKE_STT_MAX_BATCH_DURATION_MS=1200
WAKE_STT_MAX_IN_FLIGHT=4
WAKE_STREAM_MIN_AUDIO_DURATION_SEC=1
WAKE_STREAM_SUBMIT_INTERVAL_SEC=1
WAKE_STREAM_CONFIRM_THRESHOLD=1
WAKE_STREAM_MAX_BUFFER_DURATION_SEC=15
WAKE_STREAM_IDLE_TIMEOUT_SEC=5
# Optional fixed-mode override. Leave empty for dashboard-linked auto discovery.
VEXA_NATIVE_MEETING_ID=
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
GROQ_MAX_COMPLETION_TOKENS=768
GROQ_RETRY_MAX_COMPLETION_TOKENS=1536
AIVIS_API_KEY=
AIVIS_MODEL_UUID=18972473-ca36-4e06-a33a-5cc14adba0c4
AIVIS_OUTPUT_FORMAT=wav
AIVIS_OUTPUT_SAMPLING_RATE=24000
AIVIS_LEADING_SILENCE_SECONDS=0.05
AIVIS_TRAILING_SILENCE_SECONDS=0.7
AIVIS_LINE_BREAK_SILENCE_SECONDS=0.2
WAKE_WORDS=カボス,ねえカボス,カボスさん,かぼす,カボちゃん,カーブス
WAKE_COOLDOWN_MS=0
WAKE_SAME_SPEAKER_DEDUPE_MS=0
WAKE_INPUT_SETTLE_MS=800
WAKE_MAX_INPUT_MS=2500
WAKE_STABILIZED_DUPLICATE_MS=20000
WAKE_ACK_ENABLED=true
WAKE_ACK_TEXT=うん！
WAKE_ACK_MAX_LAG_MS=3000
WAKE_ACK_MIN_ANSWER_GAP_MS=700
WAKE_RESPONSE_PLAYBACK_GUARD_MS=1000
WAKE_SPEECH_EVENT_POLL_MS=1000
WAKE_USE_PENDING_TRANSCRIPTS=true
WAKE_USE_CONFIRMED_TRANSCRIPTS=false
WAKE_CHAT_ENABLED=true
WAKE_CHAT_BOOTSTRAP_ENABLED=true
WAKE_CHAT_RECENT_LIMIT=30
WAKE_CHAT_RECENT_MINUTES=15
WAKE_CHAT_SAME_TEXT_DEDUPE_MS=3000
WAKE_CHAT_MAX_MESSAGE_CHARS=1000
WAKE_CHAT_BOT_SENDER_NAMES=カボス,Kabosu,kabosu,Vexa Bot
WAKE_CHAT_EMPTY_PROMPT=呼ばれたよ。要約、整理、チャット内容の確認、次アクション出しができます。
BOT_ECHO_COOLDOWN_MS=2000
WAKE_STT_FAST_COMMAND_STABILITY_MS=500

# Agent API — Claude credentials (optional, for agent-api service)
CLAUDE_CREDENTIALS_PATH=
CLAUDE_JSON_PATH=

# Billing hooks (optional — for hosted service)
# POST_MEETING_HOOKS=https://your-billing-webhook

# --- Vexa Environment ---
# Copy to repo root as .env:  cp deploy/env-example .env
# Then edit the REQUIRED fields below.

# ============================================================================
# REQUIRED — you MUST set these
# ============================================================================

# Transcription service
# Get a key at vexa.ai OR self-host services/transcription-service/ with GPU
TRANSCRIPTION_SERVICE_URL=https://transcription.vexa.ai/v1/audio/transcriptions
TRANSCRIPTION_SERVICE_TOKEN=your-token

# Optional: Soniox async diarization for the post-meeting (deferred) transcript
# (issues #21/#22 — per-segment speaker clusters + cluster naming).
# Set the model to stt-async-* to route the deferred path to Soniox and give
# transcription-service the API key. Leave unset to keep Whisper (DOM mapping).
#DEFERRED_TRANSCRIPTION_MODEL=stt-async-v5
#SONIOX_API_KEY=your-soniox-key
# Deferred-only STT endpoint override (realtime keeps TRANSCRIPTION_SERVICE_URL).
# Use when realtime runs on a different backend (e.g. host whisper-server)
# than the Soniox-capable transcription-service.
#DEFERRED_TRANSCRIPTION_SERVICE_URL=http://docker.for.mac.localhost:8092/v1/audio/transcriptions
#DEFERRED_TRANSCRIPTION_SERVICE_TOKEN=

# ============================================================================
# Ports — change these to avoid conflicts with other stacks
# ============================================================================
API_GATEWAY_HOST_PORT=8056
ADMIN_API_PORT=8057
RUNTIME_API_PORT=8090
AGENT_API_PORT=8100
CALENDAR_SERVICE_PORT=8050
DASHBOARD_HOST_PORT=3001
POSTGRES_HOST_PORT=5458
MCP_HOST_PORT=18888
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
WAKE_STT_HOST_PORT=8058

# ============================================================================
# Defaults — work as-is for local dev
# ============================================================================

# Admin
ADMIN_TOKEN=changeme

# Image tag — pre-built from DockerHub by default.
# `make build` writes a local tag to .last-tag which overrides this.
IMAGE_TAG=latest
BROWSER_IMAGE=vexaai/vexa-bot:latest


# Database (embedded postgres by default)
DB_NAME=vexa
DB_USER=postgres
DB_PASSWORD=postgres
# For external DB, uncomment:
# REMOTE_DB=true
# DB_HOST=your-postgres-host
# DB_PORT=5432

# Storage (embedded minio by default)
STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=vexa-access-key
MINIO_SECRET_KEY=vexa-secret-key
MINIO_BUCKET=vexa
MINIO_SECURE=false

# Google Cloud Storage backend (issue #1) — recordings source of truth with a
# 14d Standard -> Nearline / 60d delete lifecycle. Uses ADC / Workload Identity
# (no HMAC key in the app); signed URLs via IAM signBlob. See deploy/gcs/README.md.
# STORAGE_BACKEND=gcs
# GCS_BUCKET=vexa-recordings
# GCS_PROJECT=                       # optional; inferred from ADC if omitted
# GCS_SIGNING_SERVICE_ACCOUNT=       # optional; runtime SA email for signBlob, derived from ADC if omitted
# GOOGLE_CLOUD_PROJECT=              # optional; defaults to GCS_PROJECT in compose
# GOOGLE_APPLICATION_CREDENTIALS_HOST=~/.config/gcloud/application_default_credentials.json
# GOOGLE_APPLICATION_CREDENTIALS=/var/secrets/google/application_default_credentials.json

# Local GPU transcription (uncomment to self-host)
# LOCAL_TRANSCRIPTION=true

# Kabosu Calendar auto-join + Drive export (optional; run compose with profile `calendar`)
# Flow:
#   1. Invite e@bonginkan.ai to a Google Calendar event with a Meet URL.
#      If Kabosu/Codex should create test meetings too, the OAuth token needs
#      calendar.events in addition to calendar.readonly and drive.file.
#   2. calendar-service starts カボス shortly before the event.
#   3. meeting-api exports the final transcript Markdown to the Drive folder.
# Get KABOSU_GOOGLE_REFRESH_TOKEN with:
#   GOOGLE_CLIENT_ID=... GOOGLE_CLIENT_SECRET=... scripts/google-oauth-refresh-token.py
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KABOSU_CALENDAR_MODE=single_account
KABOSU_CALENDAR_ACCOUNT_EMAIL=e@bonginkan.ai
KABOSU_GOOGLE_REFRESH_TOKEN=
KABOSU_BOT_OWNER_USER_ID=
# KABOSU_DRIVE_FOLDER_ID may be a My Drive or Shared Drive folder id
# (Shared Drive uploads are supported via supportsAllDrives).
KABOSU_DRIVE_FOLDER_ID=
KABOSU_BOT_NAME=カボス
KABOSU_BOT_LANGUAGE=ja
KABOSU_VOICE_AGENT_ENABLED=false
# Issue #25 — 参加者別音声レーン録音（Google Meet、opt-in）。
# ストレージ/STTコストが参加者数に比例して増えるため既定はfalse。
RECORD_PARTICIPANT_LANES=false
# 同時録音レーン数の上限（bot側）
MAX_RECORDING_LANES=8
# レーンSTTの同時実行数（meeting-api側）
LANE_STT_CONCURRENCY=2
# 会議あたりレーン音声の合計上限秒数。超過時は混合masterへフォールバック
MAX_LANE_TOTAL_DURATION_SECONDS=14400
# Issue #26 — 同室共有マイク検出のfalse-split guard。1レーン内のクラスタが
# 「安定」と見なされるための合計発話時間（秒）／合計トークン数の閾値。
# 両方の閾値を満たすクラスタが2つ以上あるレーンは「共有マイク」と判定され、
# 各サブクラスタは要確認（needs_review）扱いになる（DOM話者名は使わない）。
LANE_SHARED_MIC_MIN_CLUSTER_DURATION_S=2.0
LANE_SHARED_MIC_MIN_CLUSTER_TOKENS=5
KABOSU_DRIVE_EXPORT_ENABLED=true
# Set to true to export only Google Calendar-origin meetings.
# Default (false) exports every completed meeting, including manual joins.
KABOSU_DRIVE_EXPORT_CALENDAR_ONLY=false
CALENDAR_SYNC_INTERVAL=300
CALENDAR_LEAD_TIME=2

# Optional Piper TTS service. Kabosu wake replies use Aivis Cloud audio_base64;
# enable compose profile `tts` only when you need text /speak through Piper.

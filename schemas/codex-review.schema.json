{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://local/codex-review.schema.json",
  "title": "Codex Ultra Review Summary",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "status",
    "mode",
    "model",
    "reasoning_effort",
    "sandbox",
    "target_kind",
    "target_hash",
    "prompt_hash",
    "response_hash",
    "response_path",
    "verdict",
    "findings",
    "adoption_status",
    "open_must_fix_count",
    "not_source_of_truth"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "task_id": {"type": "string"},
    "status": {"const": "completed"},
    "mode": {"enum": ["plan", "post", "stuck"]},
    "model": {"const": "gpt-5.6-sol"},
    "reasoning_effort": {"const": "ultra"},
    "sandbox": {"const": "read-only"},
    "target_kind": {"enum": ["plan", "diff"]},
    "target_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "prompt_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "response_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "response_path": {"type": "string"},
    "verdict": {"enum": ["MUST_FIX", "SHOULD_FIX", "SHIP"]},
    "confidence": {"type": "string"},
    "summary": {"type": "string"},
    "findings": {"type": "array"},
    "adoption_status": {"type": "array"},
    "open_must_fix_count": {"type": "integer", "minimum": 0},
    "not_source_of_truth": {"const": true}
  },
  "additionalProperties": true
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://local/dual-review-consensus.schema.json",
  "title": "Fable and Codex Sol Ultra Consensus",
  "type": "object",
  "required": ["schema_version", "task_id", "stage", "target_kind", "target_hash", "round", "max_rounds", "agreed", "fable", "codex", "brief_hash"],
  "properties": {
    "schema_version": {"type": "string"},
    "task_id": {"type": "string"},
    "stage": {"enum": ["plan", "post"]},
    "target_kind": {"enum": ["plan", "diff"]},
    "target_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "round": {"type": "integer", "minimum": 1},
    "max_rounds": {"type": "integer", "minimum": 1},
    "agreed": {"type": "boolean"},
    "fable": {"$ref": "#/definitions/decision"},
    "codex": {"$ref": "#/definitions/decision"},
    "brief_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  },
  "definitions": {
    "decision": {
      "type": "object",
      "required": ["verdict", "summary", "confidence", "blockers"],
      "properties": {
        "verdict": {"enum": ["AGREE", "MUST_FIX", "ESCALATE"]},
        "summary": {"type": "string"},
        "confidence": {"type": "string"},
        "blockers": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

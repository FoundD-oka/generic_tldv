{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://local/harness-adapter.schema.json",
  "title": "Harness Adapter Contract",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "kind",
    "source",
    "entrypoints",
    "contracts",
    "safety",
    "validation"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "kind": {
      "type": "string"
    },
    "source": {
      "type": "object"
    },
    "entrypoints": {
      "type": "object"
    },
    "contracts": {
      "type": "object",
      "required": [
        "inputs",
        "outputs",
        "evidence"
      ],
      "properties": {
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "safety": {
      "type": "object"
    },
    "validation": {
      "type": "object"
    }
  },
  "additionalProperties": true
}

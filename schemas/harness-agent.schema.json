{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://local/harness-agent.schema.json",
  "title": "Harness Agent Profile",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "kind",
    "runtime_profile",
    "purpose",
    "context_policy",
    "outputs"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "kind": {
      "type": "string"
    },
    "runtime_profile": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "model_policy": {
      "type": "object"
    },
    "context_policy": {
      "type": "object",
      "required": [
        "required"
      ],
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}

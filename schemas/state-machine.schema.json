{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://local/state-machine.schema.json",
  "title": "Backcast State Machine",
  "type": "object",
  "required": [
    "schema_version",
    "states",
    "transitions",
    "terminal_states"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "terminal_states": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "transitions": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "invariants": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
